{
  "name": "wtf",
  "version": "3.7.15",
  "description": "WTF Chrome Extension that allows you to send messages in bulk via WhatsApp™ Web",
  "main": "index.js",
  "engines": {
    "bun": ">=1.2.3"
  },
  "packageManager": "bun@1.2.3",
  "scripts": {
    "watch": "webpack --mode development --watch --progress",
    "dev": "tsc && webpack --mode development",
    "version:bump": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('./package.json','utf8'));const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n');const m=JSON.parse(fs.readFileSync('./public/manifest.json','utf8'));m.version=p.version;fs.writeFileSync('./public/manifest.json',JSON.stringify(m,null,2)+'\\n');console.log('v'+p.version)\"",
    "build": "bun run version:bump && tsc && webpack",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && yarn format",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": "Marcos V.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcosvrs/wtf.git"
  },
  "dependencies": {
    "@wppconnect/wa-js": "^3.22.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.27",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "8.4.49",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "qrcode-terminal": "^0.12.0",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  }
}
