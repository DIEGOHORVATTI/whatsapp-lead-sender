{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "3.7.44",
  "action": {
    "default_icon": {
      "16": "icons/wtf16.png",
      "32": "icons/wtf32.png",
      "48": "icons/wtf48.png",
      "64": "icons/wtf64.png",
      "128": "icons/wtf128.png",
      "256": "icons/wtf256.png",
      "512": "icons/wtf512.png",
      "1024": "icons/wtf1024.png"
    },
    "default_title": "WA Sender Pro"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "default_locale": "en",
  "description": "__MSG_appDesc__",
  "icons": {
    "16": "icons/wtf16.png",
    "32": "icons/wtf32.png",
    "48": "icons/wtf48.png",
    "64": "icons/wtf64.png",
    "128": "icons/wtf128.png",
    "256": "icons/wtf256.png",
    "512": "icons/wtf512.png",
    "1024": "icons/wtf1024.png"
  },
  "author": "wtf@marcosvr.com",
  "content_scripts": [
    {
      "js": ["js/content_script.js"],
      "matches": ["https://web.whatsapp.com/*"],
      "run_at": "document_start"
    },
    {
      "js": ["js/wppconnect-wa.js"],
      "matches": ["https://web.whatsapp.com/*"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "js": ["js/wa-js.js"],
      "matches": ["https://web.whatsapp.com/*"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://web.whatsapp.com/*"]
  },
  "homepage_url": "https://github.com/marcosvrs/wtf",
  "permissions": ["activeTab", "tabs", "storage", "sidePanel"],
  "short_name": "WA Sender Pro",
  "storage": {
    "managed_schema": "schema.json"
  },
  "web_accessible_resources": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "resources": ["js/wa-js.js", "js/wppconnect.js"]
    }
  ]
}
